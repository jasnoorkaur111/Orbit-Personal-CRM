# ============================================================================
# Orbit — environment variables
# Copy this file to `.env.local` and fill in the values. Never commit .env.local.
# ============================================================================

# ── Supabase (REQUIRED) ──────────────────────────────────────────────────────
# Create a project at https://supabase.com, then find these under
# Project Settings → API. Run migrations/000_init_schema.sql in the SQL editor.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only; bypasses RLS

# ── App URL (REQUIRED) ───────────────────────────────────────────────────────
# Used for OAuth redirect URIs and metadata. Use http://localhost:3000 in dev.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── AI provider (REQUIRED for voice capture, research, synthesis) ────────────
# Orbit uses Google Gemini for parsing/synthesis and OpenAI for some research.
# You can run with just one if you don't need every AI feature.
#
# Option A — Gemini via API key (simplest):
GEMINI_API_KEY=your-gemini-api-key
#
# Option B — Gemini via Google Vertex AI (service account). Provide the service
# account JSON as a single-line string and set the project/location:
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account",...}
# GCP_PROJECT_ID=your-gcp-project-id
# GCP_LOCATION=us-central1
#
# OpenAI (used by deep contact research + event enrichment):
OPENAI_API_KEY=your-openai-api-key

# ── Google OAuth + Calendar (OPTIONAL — enables Google sign-in & sync) ────────
# Create credentials at https://console.cloud.google.com → APIs & Services.
# Authorized redirect URI: ${NEXT_PUBLIC_APP_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Optional: a public iCal URL to sync without OAuth
# GOOGLE_CALENDAR_ICAL_URL=

# ── Microsoft OAuth + Calendar (OPTIONAL — enables Outlook/Microsoft sync) ────
# Register an app at https://portal.azure.com → App registrations.
# Redirect URI: ${NEXT_PUBLIC_APP_URL}/api/auth/microsoft/callback
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
MICROSOFT_TENANT_ID=common
# Optional: a public Outlook iCal URL to sync without OAuth
# OUTLOOK_CALENDAR_ICAL_URL=
